# env — never commit secrets; example templates stay tracked (do not add them here)
.env
.env.*
!.env.example
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE (optional local settings; commit .vscode/extensions.json if you use recommended extensions)
.idea/

# Cursor: commit .cursorignore and shared .cursor/rules — do not list .cursorignore in .gitignore
